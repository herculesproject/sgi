# #############################################################################
# PLANTILLA DE CONFIGURACIÓN LOCAL
# #############################################################################
#
# Este archivo es una plantilla. NO se debe usar directamente.
#
# Para configurar tu entorno local:
#   1. Copia este archivo:  cp .env.example .env.dev
#   2. Edita .env.dev con tus valores locales si es necesario
#
# Las tasks y launch configs de VS Code están configuradas para usar .env.dev.
#
# Los archivos .env locales están excluidos del repositorio (.gitignore).
# Solo este .env.example se versiona como referencia.
# #############################################################################

# =============================================================================
# URLs DE LOS SERVICIOS
# =============================================================================
# URLs de referencia para el resto de secciones.
# No es necesario ni recomendable cambiar las variables de las urls
# derivadas de secciones posteriores para mantener la coherencia entre
# frontend y backend.

BASE_URL=http://localhost

AUTH_URL=http://localhost:8080/auth

CNF_URL=${BASE_URL}:4288
COM_URL=${BASE_URL}:4286
CSP_URL=${BASE_URL}:4281
EER_URL=${BASE_URL}:4290
ETI_URL=${BASE_URL}:4280
PII_URL=${BASE_URL}:4283
PRC_URL=${BASE_URL}:4289
REL_URL=${BASE_URL}:4284
REP_URL=${BASE_URL}:4287
TP_URL=${BASE_URL}:4285
USR_URL=${BASE_URL}:4282
WEB_URL=${BASE_URL}:4200

ESB_URL=http://localhost:8290
SGDOC_URL=${ESB_URL}/sgdoc
SGE_URL=${ESB_URL}/sge
SGEMP_URL=${ESB_URL}/sgemp
SGEPII_URL=${ESB_URL}/sgepii
SGO_URL=${ESB_URL}/sgo
SGP_URL=${ESB_URL}/sgp


# =============================================================================
# CONFIGURACIÓN FRONTEND
# =============================================================================

## Variables usadas por proxy.conf.js para redirigir las peticiones del front
SGI_AUTH_URL=${AUTH_URL}
SGI_CNF_URL=${CNF_URL}
SGI_COM_URL=${COM_URL}
SGI_CSP_URL=${CSP_URL}
SGI_EER_URL=${EER_URL}
SGI_ETI_URL=${ETI_URL}
SGI_PII_URL=${PII_URL}
SGI_PRC_URL=${PRC_URL}
SGI_REL_URL=${REL_URL}
SGI_REP_URL=${REP_URL}
SGI_SGDOC_URL=${ESB_URL}
SGI_SGE_URL=${ESB_URL}
SGI_SGEMP_URL=${ESB_URL}
SGI_SGEPII_URL=${ESB_URL}
SGI_SGO_URL=${ESB_URL}
SGI_SGP_URL=${ESB_URL}
SGI_TP_URL=${TP_URL}
SGI_USR_URL=${USR_URL}

## Variables con prefijo environment_ que se inyectan en environment.ts
## usando generate-config.dev.js
environment_authConfig_ssoUrl=${AUTH_URL}


# =============================================================================
# CONFIGURACIÓN BACKEND
# =============================================================================
## Estas propiedades se aplican a todos los microservicios que se arranquen en local

## Configuración OAuth2 / Keycloak
SPRING_SECURITY_OAUTH2_CLIENT_PROVIDER_KEYCLOAK_ISSUERURI=${AUTH_URL}/realms/sgi
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWKSETURI=${SPRING_SECURITY_OAUTH2_CLIENT_PROVIDER_KEYCLOAK_ISSUERURI}/protocol/openid-connect/certs

## URLs de comunicación entre microservicios
SGI_REST_API_CNFURL=${SGI_CNF_URL}
SGI_REST_API_COMURL=${SGI_COM_URL}
SGI_REST_API_ETIURL=${SGI_ETI_URL}
SGI_REST_API_PIIURL=${SGI_PII_URL}
SGI_REST_API_PRCURL=${SGI_PRC_URL}
SGI_REST_API_RELURL=${SGI_REL_URL}
SGI_REST_API_REPURL=${SGI_REP_URL}
SGI_REST_API_SGDOCURL=${SGI_SGDOC_URL}
SGI_REST_API_SGEMPURL=${SGEMP_URL}
SGI_REST_API_SGEPIIURL=${SGEPII_URL}
SGI_REST_API_SGEURL=${SGE_URL}
SGI_REST_API_SGOURL=${SGO_URL}
SGI_REST_API_SGPURL=${SGP_URL}
SGI_REST_API_TPURL=${SGI_TP_URL}
SGI_REST_API_USRURL=${SGI_USR_URL}
SGI_REST_API_WEBURL=${SGI_USR_URL}

# =============================================================================
# LOGGING
# =============================================================================

## Nivel de log global por defecto (TRACE, DEBUG, INFO, WARN, ERROR, OFF)
# LOGGING_LEVEL_ROOT=INFO

## Nivel de log para todo el SGI (incluido el log del sgi-framework-spring)
# LOGGING_LEVEL_ORG_CRUE_HERCULES_SGI=INFO

## Nivel de log por cada servicio
# LOGGING_LEVEL_ORG_CRUE_HERCULES_SGI_CNF=DEBUG
# LOGGING_LEVEL_ORG_CRUE_HERCULES_SGI_COM=DEBUG
# LOGGING_LEVEL_ORG_CRUE_HERCULES_SGI_CSP=DEBUG
# LOGGING_LEVEL_ORG_CRUE_HERCULES_SGI_EER=DEBUG
# LOGGING_LEVEL_ORG_CRUE_HERCULES_SGI_ETI=DEBUG
# LOGGING_LEVEL_ORG_CRUE_HERCULES_SGI_PPI=DEBUG
# LOGGING_LEVEL_ORG_CRUE_HERCULES_SGI_PRC=DEBUG
# LOGGING_LEVEL_ORG_CRUE_HERCULES_SGI_REL=DEBUG
# LOGGING_LEVEL_ORG_CRUE_HERCULES_SGI_REP=DEBUG
# LOGGING_LEVEL_ORG_CRUE_HERCULES_SGI_TP=DEBUG
# LOGGING_LEVEL_ORG_CRUE_HERCULES_SGI_USR=DEBUG

## Muestra las queries SQL generadas por Hibernate
# LOGGING_LEVEL_ORG_HIBERNATE_SQL=DEBUG

## Valores de los parametros que se asignan a las queries
# LOGGING_LEVEL_ORG_HIBERNATE_TYPE_DESCRIPTOR_SQL_BASICBINDER=TRACE

## Formatea el SQL para que sea más legible en logs
# SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true

## Genera estadísticas de Hibernate (queries ejecutadas, tiempo, ...)
# SPRING_JPA_PROPERTIES_HIBERNATE_GENERATE_STATISTICS=true


# =============================================================================
# LIQUIBASE
# =============================================================================

## Contexto de Liquibase
# SPRING_LIQUIBASE_CONTEXTS=dev
