  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "type": "shell",
        "command": "npm start",
        "label": "Start sgi-webapp",
        "isBackground": true,
        "options": {
          "cwd": "${workspaceFolder:sgi-webapp}",
          "env": {
            "SGI_ENV_FILE": "../.env.dev"
          }
        },
        "problemMatcher": {
          "owner": "custom",
          "pattern": {
            "regexp": "$^"
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".",
            "endsPattern": "Angular Live Development Server is listening"
          }
        }
      },
      {
        "label": "Stop sgi-webapp",
        "type": "shell",
        "command": "pkill -f 'ng serve sgi-webapp'",
        "problemMatcher": []
      },
      {
        "label": "Start sgi-auth",
        "type": "docker-run",
        "dockerRun": {
          "containerName": "sgi-auth",
          "image": "herculesproject/sgi-auth:${input:sgi-auth-version}",
          "network": "sgi-dev-network",
          "env": {
            "KEYCLOAK_IMPORT": "/realm/sgi-realm.json",
            "KEYCLOAK_USER": "admin",
            "KEYCLOAK_PASSWORD": "password",
            "KEYCLOAK_MIGRATION_STRATEGY": "OVERWRITE_EXISTING",
            "PROXY_ADDRESS_FORWARDING": "true"
          },
          "remove": true,
          "ports": [
            {
              "hostPort": 8080,
              "containerPort": 8080
            }
          ]
        }
      },
      {
        "label": "Stop sgi-auth",
        "type": "shell",
        "command": "docker stop sgi-auth 2>/dev/null; true",
        "problemMatcher": []
      },
      {
        "label": "Start sgi-esb",
        "type": "docker-run",
        "dockerRun": {
          "containerName": "sgi-esb",
          "image": "herculesproject/sgi-esb-reference-imp:${input:sgi-esb-version}",
          "network": "sgi-dev-network",
          "env": {
            "SGI_ESB_AUTH_SERVER_REALM_ID": "sgi",
            "SGI_ESB_AUTH_SERVER_URL": "http://sgi-auth:8080/auth",
            "SGI_ESB_CONTEXT": "dev",
            "SGI_ESB_SGDOC_SERVICE_URL": "http://sgi-sgdoc:4300",
            "SGI_ESB_SGE_SERVICE_URL": "http://sgi-sge:4301",
            "SGI_ESB_SGEMP_SERVICE_URL": "http://sgi-sgemp:4302",
            "SGI_ESB_SGEPII_SERVICE_URL": "http://sgi-sge:4301",
            "SGI_ESB_SGICSP_SERVICE_URL": "http://localhost:4281",
            "SGI_ESB_SGIEER_SERVICE_URL": "http://localhost:4290",
            "SGI_ESB_SGIPII_SERVICE_URL": "http://localhost:4283",
            "SGI_ESB_SGIPRC_SERVICE_URL": "http://localhost:4289",
            "SGI_ESB_SGIUSR_SERVICE_URL": "http://localhost:4282",
            "SGI_ESB_SGO_SERVICE_URL": "http://sgi-sgo:4303",
            "SGI_ESB_SGP_SERVICE_URL": "http://sgi-sgp:4304",
          },
          "remove": true,
          "ports": [
            {
              "hostPort": 8290,
              "containerPort": 8290
            }
          ]
        }
      },
      {
        "label": "Start sgdoc",
        "type": "docker-run",
        "dockerRun": {
          "containerName": "sgi-sgdoc",
          "image": "herculesproject/sgi-external-sgdoc-reference-imp:${input:sgdoc-version}",
          "network": "sgi-dev-network",
          "remove": true,
          "env": {
            "SERVER_PORT": "4300",
            "SPRING_PROFILES_ACTIVE": "dev"
          }
        }
      },
      {
        "label": "Start sge",
        "type": "docker-run",
        "dockerRun": {
          "containerName": "sgi-sge",
          "image": "herculesproject/sgi-external-sge-reference-imp:${input:sge-version}",
          "network": "sgi-dev-network",
          "remove": true,
          "env": {
            "SERVER_PORT": "4301",
            "SPRING_PROFILES_ACTIVE": "dev"
          }
        }
      },
      {
        "label": "Start sgemp",
        "type": "docker-run",
        "dockerRun": {
          "containerName": "sgi-sgemp",
          "image": "herculesproject/sgi-external-sgemp-reference-imp:${input:sgemp-version}",
          "network": "sgi-dev-network",
          "remove": true,
          "env": {
            "SERVER_PORT": "4302",
            "SPRING_PROFILES_ACTIVE": "dev"
          }
        }
      },
      {
        "label": "Start sgo",
        "type": "docker-run",
        "dockerRun": {
          "containerName": "sgi-sgo",
          "image": "herculesproject/sgi-external-sgo-reference-imp:${input:sgo-version}",
          "network": "sgi-dev-network",
          "remove": true,
          "env": {
            "SERVER_PORT": "4303",
            "SPRING_PROFILES_ACTIVE": "dev"
          }
        }
      },
      {
        "label": "Start sgp",
        "type": "docker-run",
        "dockerRun": {
          "containerName": "sgi-sgp",
          "image": "herculesproject/sgi-external-sgp-reference-imp:${input:sgp-version}",
          "network": "sgi-dev-network",
          "remove": true,
          "env": {
            "SERVER_PORT": "4304",
            "SPRING_PROFILES_ACTIVE": "dev"
          }
        }
      },
      {
        "label": "Start sgi-esb stack",
        "dependsOn": [
          "Start sgp",
          "Start sgdoc",
          "Start sge",
          "Start sgemp",
          "Start sgo",
          "Start sgi-esb"
        ],
        "dependsOrder": "parallel",
        "problemMatcher": []
      },
      {
        "label": "Stop sgi-esb stack",
        "type": "shell",
        "command": "docker stop sgi-esb sgi-sgp sgi-sgdoc sgi-sge sgi-sgemp sgi-sgo 2>/dev/null; true",
        "problemMatcher": []
      }
    ],
    "inputs": [
      {
        "type": "promptString",
        "id": "sgi-auth-version",
        "description": "sgi-auth version",
        "default": "ci"
      },
      {
        "type": "promptString",
