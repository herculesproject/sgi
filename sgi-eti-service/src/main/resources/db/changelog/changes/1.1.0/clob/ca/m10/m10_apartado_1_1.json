[
  {
    "key": "ap1_1",
    "wrappers": [
      "expansion-panel"
    ],
    "templateOptions": {
      "expressionLock": "formState.memoria.tipo === 'RATIFICACION'",
      "label": "1.1 Valor social del projecte"
    },
    "fieldGroup": [
      {
        "wrappers": [
          "info-div"
        ],
        "template": "Aquesta secció s'emplena automàticament a partir de les dades introduïdes al camp <b>Valor social</b> de l'apartat <a href='#MODULE_PATH#/peticiones-evaluacion/#PETICION_EVALUACION_ID#/dades-generales' target='_blank'><b>Dades generals</b></a>. Accediu a aquest punt del menú per realitzar les modificacions necessàries.",
        "templateOptions": {
          "replaceTemplatePlaceholders": true
        }
      },
      {
        "template": "<p>A continuació es mostra la finalitat principal del projecte: el tema en què s'espera un augment del coneixement o un benefici social últim que en justifiqui la realització.</p>"
      },
      {
        "key": "valorSocial",
        "type": "tipo-valor-social",
        "templateOptions": {
          "label": "Valor social",
          "placeholder": "",
          "required": true,
          "disabled": true,
          "expressionModelValue": "formState.memoria.peticionEvaluacion.valorSocial"
        }
      },
      {
        "key": "otroValorSocial",
        "type": "i18n-textarea",
        "hideExpression": "formState.memoria.peticionEvaluacion.valorSocial !== 'OTRA_FINALIDAD'",
        "templateOptions": {
          "placeholder": "Especificar",
          "label": "Especificar",
          "disabled": true,
          "autosize": true,
          "autosizeMinRows": "1",
          "autosizeMaxRows": "10",
          "expressionModelValue": "formState.memoria.peticionEvaluacion.otroValorSocial"
        }
      }
    ]
  }
]