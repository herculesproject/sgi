[
  {
    "key": "ap3_4_4",
    "wrappers": [
      "title-div"
    ],
    "templateOptions": {
      "expressionLock": "formState.memoria.tipo === 'RATIFICACION'",
      "label": "3.4.4 Incentius per a la participació"
    },
    "hideExpression": "!formState.mainModel.ap3_4.intervencionesSeresHumanosRadio || formState.mainModel.ap3_4.intervencionesSeresHumanosRadio === 'no'",
    "fieldGroup": [
      {
        "template": "<p>¿Es donarà algun tipus d'incentiu o compensació al subjecte d'estudi per la seva participació?</p>"
      },
      {
        "key": "incentivosParticipacionRadio",
        "type": "radio",
        "templateOptions": {
          "label": "Trieu opció:",
          "required": true,
          "options": [
            {
              "value": "no",
              "label": "No"
            },
            {
              "value": "si",
              "label": "Sí"
            }
          ]
        }
      },
      {
        "template": "<p>Especificar tipus d'incentiu, quantia i justificació</p>",
        "hideExpression": "!model.incentivosParticipacionRadio || model.incentivosParticipacionRadio === 'no'"
      },
      {
        "key": "incentivosParticipacionTexto",
        "type": "i18n-textarea",
        "hideExpression": "!model.incentivosParticipacionRadio || model.incentivosParticipacionRadio === 'no'",
        "templateOptions": {
          "label": "Incentius",
          "placeholder": "Incentius",
          "required": true,
          "autosize": true,
          "autosizeMinRows": "1",
          "autosizeMaxRows": "10"
        }
      }
    ]
  }
]