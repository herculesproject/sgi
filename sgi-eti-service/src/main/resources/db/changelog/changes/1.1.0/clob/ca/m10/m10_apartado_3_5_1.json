[
  {
    "key": "ap3_5_1",
    "wrappers": [
      "title-div"
    ],
    "templateOptions": {
      "expressionLock": "formState.memoria.tipo === 'RATIFICACION'",
      "label": "3.5.1 Origen de les mostres"
    },
    "hideExpression": "!formState.mainModel.ap3_5.muestrasBiologicasRadio || formState.mainModel.ap3_5.muestrasBiologicasRadio === 'no'",
    "fieldGroup": [
      {
        "template": "Com s'han obtingut les mostres?"
      },
      {
        "type": "multicheckbox",
        "key": "origenMuestrasCheck",
        "templateOptions": {
          "label": "Origen",
          "type": "array",
          "required": true,
          "options": [
            {
              "value": "recogidasExpresamente",
              "label": "Recollides expressament per a aquest projecte amb intervenció del subjecte destudi (ha de contestar afirmativament a la pregunta 3.4)"
            },
            {
              "value": "recogidasApartirDeMuestras",
              "label": "Recollides a partir de mostres ja obtingudes en un altre procés (ex. clínic-assistencial, autòpsia)*"
            },
            {
              "value": "procedentesBiobanco",
              "label": "Procedents de Biobanc*"
            },
            {
              "value": "procedentesColeccion",
              "label": "Procedents d'una col·lecció de mostres*"
            }
          ]
        }
      },
      {
        "key": "especificarRecogidasApartirDeMuestras",
        "type": "i18n-textarea",
        "hideExpression": "!model.origenMuestrasCheck || !model.origenMuestrasCheck.some(origen => origen === 'recogidasApartirDeMuestras')",
        "templateOptions": {
          "label": "Especificar recollides a partir de mostres ja obtingudes",
          "placeholder": "Especificar recollides a partir de mostres ja obtingudes",
          "required": true,
          "autosize": true,
          "autosizeMinRows": "1",
          "autosizeMaxRows": "10"
        }
      },
      {
        "key": "especificarProcedentesBiobanco",
        "type": "i18n-textarea",
        "hideExpression": "!model.origenMuestrasCheck || !model.origenMuestrasCheck.some(origen => origen === 'procedentesBiobanco')",
        "templateOptions": {
          "label": "Especificar procedents de Biobanc",
          "placeholder": "Especificar procedents de Biobanc",
          "required": true,
          "autosize": true,
          "autosizeMinRows": "1",
          "autosizeMaxRows": "10"
        }
      },
      {
        "key": "especificarProcedentesColeccion",
        "type": "i18n-textarea",
        "hideExpression": "!model.origenMuestrasCheck || !model.origenMuestrasCheck.some(origen => origen === 'procedentesColeccion')",
        "templateOptions": {
          "label": "Especificar procedents d'una col·lecció de mostres",
          "placeholder": "Especificar procedents d'una col·lecció de mostres",
          "required": true,
          "autosize": true,
          "autosizeMinRows": "1",
          "autosizeMaxRows": "10"
        }
      },
      {
        "wrappers": [
          "info-div"
        ],
        "template": "<p>Nota: Les opcions marcades amb (*) requereixen MTA o conveni que cal aportar a l'apartat 5.5.</p>"
      }
    ]
  }
]