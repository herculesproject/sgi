[
  {
    "key": "ap4_6_1",
    "wrappers": [
      "title-div"
    ],
    "templateOptions": {
      "expressionLock": "formState.memoria.tipo === 'RATIFICACION'",
      "label": "4.6.1 Justificació de lús destudiants"
    },
    "hideExpression": "!formState.mainModel.ap4_6.estudiantesSujetosInvestigacionRadio || formState.mainModel.ap4_6.estudiantesSujetosInvestigacionRadio === 'no'",
    "fieldGroup": [
      {
        "template": "<p>Són els estudiants de la Universitat un grup específic de població necessari per al projecte?</p>"
      },
      {
        "key": "justificacionUsoEstudiantesRadio",
        "type": "radio",
        "templateOptions": {
          "required": true,
          "label": "Trieu opció:",
          "options": [
            {
              "value": "no",
              "label": "No"
            },
            {
              "value": "si",
              "label": "Sí"
            }
          ]
        }
      },
      {
        "template": "Motius pels quals no se'n planteja la substitució",
        "hideExpression": "!model.justificacionUsoEstudiantesRadio || model.justificacionUsoEstudiantesRadio === 'si'"
      },
      {
        "key": "motivosNoPlanteamientoSustitucion",
        "type": "i18n-textarea",
        "hideExpression": "!model.justificacionUsoEstudiantesRadio || model.justificacionUsoEstudiantesRadio === 'si'",
        "templateOptions": {
          "label": "Motius",
          "placeholder": "Motius",
          "required": true,
          "autosize": true,
          "autosizeMinRows": "1",
          "autosizeMaxRows": "10"
        }
      }
    ]
  }
]