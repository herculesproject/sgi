        "templateOptions": {
          "label": "Seleccionar",
          "options": [
            {
              "label": "No recuperació",
              "value": "1"
            },
            {
              "label": "Lleu",
              "value": "2"
            },
            {
              "label": "Moderada",
              "value": "3"
            },
            {
              "label": "Severa",
              "value": "4"
            }
          ]
        }
      },
      {
        "wrappers": [
          "info-div"
        ],
        "template": "<p>Nota: Requereix informe veterinari que cal adjuntar a l'apartat 5.2</p>"
      }
    ]
  }
