[
  {
    "key": "ap4_5_1",
    "wrappers": [
      "title-div"
    ],
    "templateOptions": {
      "expressionLock": "formState.memoria.tipo === 'RATIFICACION'",
      "label": "4.5.1 Resultat de lestudi genètic"
    },
    "hideExpression": "!formState.mainModel.ap4_5.estudiosGeneticosRadio || formState.mainModel.ap4_5.estudiosGeneticosRadio === 'no'",
    "fieldGroup": [
      {
        "template": "<p>Es pot obtenir alguna informació rellevant per a la vida o la salut del subjecte participant?</p>"
      },
      {
        "key": "resultadoEstudioGeneticoRadio",
        "type": "radio",
        "templateOptions": {
          "required": true,
          "label": "Trieu opció:",
          "options": [
            {
              "value": "no",
              "label": "No"
            },
            {
              "value": "si",
              "label": "Sí"
            }
          ]
        }
      },
      {
        "template": "<p>En cas afirmatiu especificar</p>",
        "hideExpression": "!model.resultadoEstudioGeneticoRadio || model.resultadoEstudioGeneticoRadio === 'no'"
      },
      {
        "key": "especificarResultadoEstudioGenetico",
        "type": "i18n-textarea",
        "hideExpression": "!model.resultadoEstudioGeneticoRadio || model.resultadoEstudioGeneticoRadio === 'no'",
        "templateOptions": {
          "label": "Especificar",
          "required": true,
          "autosize": true,
          "autosizeMinRows": "1",
          "autosizeMaxRows": "10"
        }
      }
    ]
  }
]