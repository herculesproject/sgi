[
  {
    "key": "ap4_6_2",
    "wrappers": [
      "title-div"
    ],
    "templateOptions": {
      "expressionLock": "formState.memoria.tipo === 'RATIFICACION'",
      "label": "4.6.2 Benefici formatiu per a l'estudiant"
    },
    "hideExpression": "!formState.mainModel.ap4_6.estudiantesSujetosInvestigacionRadio || formState.mainModel.ap4_6.estudiantesSujetosInvestigacionRadio === 'no'",
    "fieldGroup": [
      {
        "template": "<p>La participació com a subjecte de recerca reporta a algun benefici formatiu a l'estudiant?</p>"
      },
      {
        "key": "beneficioFormativoEstudianteRadio",
        "type": "radio",
        "templateOptions": {
          "required": true,
          "label": "Trieu opció:",
          "options": [
            {
              "value": "no",
              "label": "No"
            },
            {
              "value": "si",
              "label": "Sí"
            }
          ]
        }
      },
      {
        "template": "Especificar",
        "hideExpression": "!model.beneficioFormativoEstudianteRadio || model.beneficioFormativoEstudianteRadio === 'no'"
      },
      {
        "key": "especificarBeneficioFormativo",
        "type": "i18n-textarea",
        "hideExpression": "!model.beneficioFormativoEstudianteRadio || model.beneficioFormativoEstudianteRadio === 'no'",
        "templateOptions": {
          "label": "Especificar",
          "placeholder": "Especificar",
          "required": true,
          "autosize": true,
          "autosizeMinRows": "1",
          "autosizeMaxRows": "10"
        }
      }
    ]
  }
]