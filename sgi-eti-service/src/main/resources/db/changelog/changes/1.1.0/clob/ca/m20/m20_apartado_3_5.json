[
  {
    "key": "ap3_5",
    "wrappers": [
      "expansion-panel"
    ],
    "templateOptions": {
      "label": "3.5 Lloc on es realitzaran els procediments/intervencions dels animals"
    },
    "fieldGroup": [
      {
        "template": "<p>Especificar el lloc on es mantindran els animals durant el procés d'experimentació.</p>"
      },
      {
        "wrappers": [
          "info-div"
        ],
        "template": "<p>els procediments/intervencions es realitzaran en centres usuaris autoritzats, excepte autorització de l'òrgan competent, amb la justificació científica prèvia de la necessitat o conveniència que es realitzin fora d'aquests centres (<a href='https://www.boe.es/diario_boe/txt.php?id=BOE-A-2013-1337' 5) 53/13</a>)</p>"
      },
      {
        "key": "centroUsuarioUniversidadCheckPrincipal",
        "type": "checkbox",
        "templateOptions": {
          "label": "Centre usuari de la Universitat",
          "indeterminate": false
        }
      },
      {
        "key": "centroUsuarioUniversidadCheck",
        "type": "multicheckbox",
        "hideExpression": "!model.centroUsuarioUniversidadCheckPrincipal",
        "templateOptions": {
          "label": "Seleccionar",
          "required": true,
          "type": "array",
          "options": [
            {
              "value": "animalarioCampusAlava",
              "label": "Animalari 1"
            },
            {
              "value": "animalarioCampusBizkaia",
              "label": "Animalari 2"
            },
            {
              "value": "animalarioCampusGipuzkoa",
              "label": "Animalari 3"
            }
          ]
        }
      },
      {
        "key": "especificarCentroUniversidad",
        "type": "i18n-textarea",
        "hideExpression": "!(model.centroUsuarioUniversidadCheckPrincipal && model.centroUsuarioUniversidadCheck && model.centroUsuarioUniversidadCheck.find((c)=> c === 'otros'))",
        "templateOptions": {
          "label": "Especificar",
          "disabled": false,
          "required": true,
          "autosize": true,
          "autosizeMinRows": "1",
          "autosizeMaxRows": "10"
        }
      },
      {
        "key": "otroCentroRegistradoCheck",
        "type": "checkbox",
        "templateOptions": {
          "label": "Un altre centre usuari, registrat.",
          "indeterminate": false
        }
      },
      {
        "key": "especificarCentroRegistrado",
        "type": "i18n-textarea",
        "hideExpression": "!model.otroCentroRegistradoCheck",
        "templateOptions": {
          "label": "Especificar",
          "disabled": false,
          "required": true,
          "autosize": true,
          "autosizeMinRows": "1",
          "autosizeMaxRows": "10"
        }
      },
      {
        "key": "numeroRegistro",
        "type": "i18n-textarea",
        "hideExpression": "!model.otroCentroRegistradoCheck",
        "templateOptions": {
          "label": "Núm. de registre",
          "disabled": false,
          "required": true,
          "autosize": true,
          "autosizeMinRows": "1",
          "autosizeMaxRows": "10"
        }
      },
      {
        "key": "otroCentroNoRegistradoCheck",
        "type": "checkbox",
        "templateOptions": {
          "label": "Un altre centre o lloc no registrat.",
          "indeterminate": false
        }
      },
      {
        "key": "especificarCentroNoRegistrado",
        "type": "i18n-textarea",
        "hideExpression": "!model.otroCentroNoRegistradoCheck",
        "templateOptions": {
          "label": "Especificar",
          "disabled": false,
          "required": true,
          "autosize": true,
          "autosizeMinRows": "1",
          "autosizeMaxRows": "10"
        }
      },
      {
        "key": "justificar",
        "type": "i18n-textarea",
        "hideExpression": "!model.otroCentroNoRegistradoCheck",
        "templateOptions": {
          "label": "Justificar",
          "disabled": false,
          "required": true,
          "autosize": true,
          "autosizeMinRows": "1",
          "autosizeMaxRows": "10"
        }
      },
      {
        "wrappers": [
          "info-div"
        ],
        "template": "<p>Per a més informació de llocs del Centre usuari de la Universitat consulteu amb la Secretaria Tècnica del Comitè d'Ètica.</p>"
      }
    ]
  }
]