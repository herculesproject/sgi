<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
  xmlns:pro="http://www.liquibase.org/xml/ns/pro"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd
                      http://www.liquibase.org/xml/ns/pro http://www.liquibase.org/xml/ns/pro/liquibase-pro-3.8.xsd
                      http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

  <property name="schemaPrefix" value="" />
  <property name="defaultLang" value="es" />

  <changeSet author="master" id="1.1.0-1">
    <createSequence incrementBy="1" sequenceName="tipo_grupo_seq" startValue="1" />
  </changeSet>

  <changeSet author="master" id="1.1.0-2">
    <createTable tableName="tipo_grupo">
      <column name="id" type="BIGINT">
        <constraints nullable="false" primaryKey="true" primaryKeyName="tipo_grupoPK" />
      </column>
      <column name="created_by" type="VARCHAR(255)" />
      <column name="creation_date" type="TIMESTAMP" />
      <column name="last_modified_by" type="VARCHAR(255)" />
      <column name="last_modified_date" type="TIMESTAMP" />
      <column defaultValueBoolean="true" name="activo" type="BOOLEAN">
        <constraints nullable="false" />
      </column>
      <!-- Columna temporal para mapear los valores del enum en la migración -->
      <column name="codigo" type="VARCHAR(50)" />
    </createTable>
  </changeSet>

  <changeSet author="master" id="1.1.0-3">
    <createTable tableName="tipo_grupo_nombre">
      <column name="tipo_grupo_id" type="BIGINT">
        <constraints nullable="false" />
      </column>
      <column name="lang" type="VARCHAR(2)">
        <constraints nullable="false" />
      </column>
      <column name="value_" type="VARCHAR(50)">
        <constraints nullable="false" />
      </column>
    </createTable>

    <addPrimaryKey tableName="tipo_grupo_nombre" columnNames="tipo_grupo_id, lang" />

    <addForeignKeyConstraint baseColumnNames="tipo_grupo_id"
      baseTableName="tipo_grupo_nombre"
      constraintName="FK_TIPOGRUPONOMRE_TIPOGRUPO" deferrable="false"
      initiallyDeferred="false"
      referencedColumnNames="id" referencedTableName="tipo_grupo" validate="true" />
  </changeSet>

  <changeSet author="master" id="1.1.0-4">
    <createTable tableName="tipo_grupo_descripcion">
      <column name="tipo_grupo_id" type="BIGINT">
        <constraints nullable="false" />
      </column>
      <column name="lang" type="VARCHAR(2)">
        <constraints nullable="false" />
      </column>
      <column name="value_" type="VARCHAR(250)">
        <constraints nullable="false" />
      </column>
    </createTable>

    <addPrimaryKey tableName="tipo_grupo_descripcion" columnNames="tipo_grupo_id, lang" />

    <addForeignKeyConstraint baseColumnNames="tipo_grupo_id"
      baseTableName="tipo_grupo_descripcion"
      constraintName="FK_TIPOGRUPODESCRIPCION_TIPOGRUPO" deferrable="false"
      initiallyDeferred="false"
      referencedColumnNames="id" referencedTableName="tipo_grupo" validate="true" />
  </changeSet>

  <!-- Añadir FK tipo_grupo_id a grupo_tipo (nullable para poder migrar primero) -->
  <changeSet author="master" id="1.1.0-5">
    <addColumn tableName="grupo_tipo">
      <column name="tipo_grupo_id" type="BIGINT">
        <constraints nullable="true" />
      </column>
    </addColumn>

    <addForeignKeyConstraint baseColumnNames="tipo_grupo_id"
      baseTableName="grupo_tipo"
      constraintName="FK_GRUPOTIPO_TIPOGRUPO" deferrable="false"
      initiallyDeferred="false"
      referencedColumnNames="id" referencedTableName="tipo_grupo" validate="true" />
  </changeSet>

  <changeSet author="master" id="1.1.0-6">
    <addColumn tableName="grupo">
      <column name="acronimo" type="VARCHAR(50)" />
      <column name="direccion" type="VARCHAR(200)" />
      <column name="email" type="VARCHAR(200)" />
      <column name="imagen_ref" type="VARCHAR(250)" />
    </addColumn>
  </changeSet>

  <changeSet author="master" id="1.1.0-7">
    <addColumn tableName="configuracion">
      <column name="grupo_imagen_aspecto" type="VARCHAR(50)" />
      <column name="grupo_imagen_tamanio_maximo" type="DECIMAL(19, 2)" />
    </addColumn>
  </changeSet>

  <changeSet author="master" id="1.1.0-8">
    <createTable tableName="linea_investigacion_descripcion">
      <column name="linea_investigacion_id" type="BIGINT">
        <constraints nullable="false" />
      </column>
      <column name="lang" type="VARCHAR(2)">
        <constraints nullable="false" />
      </column>
      <column name="value_" type="VARCHAR(3000)">
        <constraints nullable="false" />
      </column>
    </createTable>

    <addPrimaryKey tableName="linea_investigacion_descripcion"
      columnNames="linea_investigacion_id, lang" />

    <addForeignKeyConstraint baseColumnNames="linea_investigacion_id"
      baseTableName="linea_investigacion_descripcion"
      constraintName="FK_LINEAINVESTIGACIONDESCRIPCION_LINEAINVESTIGACION" deferrable="false"
      initiallyDeferred="false"
      referencedColumnNames="id" referencedTableName="linea_investigacion" validate="true" />
  </changeSet>

  <changeSet author="master" id="1.1.0-9">
    <addColumn tableName="grupo_enlace">
      <column name="tipo_enlace_id" type="BIGINT">
        <constraints nullable="true" />
      </column>
    </addColumn>

    <addForeignKeyConstraint baseColumnNames="tipo_enlace_id"
      baseTableName="grupo_enlace"
      constraintName="FK_GRUPOENLACE_TIPOENLACE" deferrable="false"
      initiallyDeferred="false"
      referencedColumnNames="id" referencedTableName="tipo_enlace" validate="true" />
  </changeSet>


  <changeSet author="master" id="1.1.0-10">
    <createSequence sequenceName="tipo_descriptor_grupo_seq" startValue="1" incrementBy="1" />
  </changeSet>

  <changeSet author="master" id="1.1.0-11">
    <createTable tableName="tipo_descriptor_grupo">
      <column name="id" type="BIGINT">
        <constraints primaryKey="true" nullable="false" />
      </column>
      <column name="activo" type="BOOLEAN" defaultValueBoolean="true">
        <constraints nullable="false" />
      </column>
      <column name="created_by" type="VARCHAR(255)" />
      <column name="creation_date" type="TIMESTAMP" />
      <column name="last_modified_by" type="VARCHAR(255)" />
      <column name="last_modified_date" type="TIMESTAMP" />
    </createTable>
  </changeSet>

  <changeSet author="master" id="1.1.0-12">
    <createTable tableName="tipo_descriptor_grupo_nombre">
      <column name="tipo_descriptor_grupo_id" type="BIGINT">
        <constraints nullable="false" />
      </column>
      <column name="lang" type="VARCHAR(2)">
        <constraints nullable="false" />
      </column>
      <column name="value_" type="VARCHAR(50)">
        <constraints nullable="false" />
      </column>
    </createTable>

    <addPrimaryKey tableName="tipo_descriptor_grupo_nombre"
      columnNames="tipo_descriptor_grupo_id, lang" />

    <addForeignKeyConstraint baseColumnNames="tipo_descriptor_grupo_id"
      baseTableName="tipo_descriptor_grupo_nombre"
      constraintName="FK_TIPODESCRIPTORGRUPONOMBRE_TIPODESCRIPTORGRUPO"
      deferrable="false" initiallyDeferred="false"
      referencedColumnNames="id" referencedTableName="tipo_descriptor_grupo" validate="true" />
  </changeSet>

  <changeSet author="master" id="1.1.0-13">
    <createSequence sequenceName="grupo_descriptor_seq" startValue="1" incrementBy="1" />
  </changeSet>

  <changeSet author="master" id="1.1.0-14">
    <createTable tableName="grupo_descriptor">
      <column name="id" type="BIGINT">
        <constraints primaryKey="true" nullable="false" />
      </column>
      <column name="grupo_id" type="BIGINT">
        <constraints nullable="false" />
      </column>
      <column name="tipo_descriptor_grupo_id" type="BIGINT">
        <constraints nullable="false" />
      </column>
      <column name="created_by" type="VARCHAR(255)" />
      <column name="creation_date" type="TIMESTAMP" />
      <column name="last_modified_by" type="VARCHAR(255)" />
      <column name="last_modified_date" type="TIMESTAMP" />
    </createTable>

    <addForeignKeyConstraint baseColumnNames="grupo_id"
      baseTableName="grupo_descriptor"
      constraintName="FK_GRUPODESCRIPTOR_GRUPO"
      deferrable="false" initiallyDeferred="false"
      referencedColumnNames="id" referencedTableName="grupo" validate="true" />

    <addForeignKeyConstraint baseColumnNames="tipo_descriptor_grupo_id"
      baseTableName="grupo_descriptor"
      constraintName="FK_GRUPODESCRIPTOR_TIPODESCRIPTORGRUPO"
      deferrable="false" initiallyDeferred="false"
      referencedColumnNames="id" referencedTableName="tipo_descriptor_grupo" validate="true" />
  </changeSet>

  <changeSet author="master" id="1.1.0-15">
    <createTable tableName="grupo_descriptor_texto">
      <column name="grupo_descriptor_id" type="BIGINT">
        <constraints nullable="false" />
      </column>
      <column name="lang" type="VARCHAR(2)">
        <constraints nullable="false" />
      </column>
      <column name="value_" type="VARCHAR(3000)">
        <constraints nullable="false" />
      </column>
    </createTable>

    <addPrimaryKey tableName="grupo_descriptor_texto"
      columnNames="grupo_descriptor_id, lang" />

    <addForeignKeyConstraint baseColumnNames="grupo_descriptor_id"
      baseTableName="grupo_descriptor_texto"
      constraintName="FK_GRUPODESCRIPTORTEXTO_GRUPODESCRIPTOR"
      deferrable="false" initiallyDeferred="false"
      referencedColumnNames="id" referencedTableName="grupo_descriptor" validate="true" />
  </changeSet>

  <changeSet author="master" id="1.1.0-16">
    <createSequence incrementBy="1" sequenceName="grupo_relacion_institucional_seq" startValue="1" />
  </changeSet>

  <changeSet author="master" id="1.1.0-17">
    <createTable tableName="grupo_relacion_institucional">
      <column name="id" type="BIGINT">
        <constraints nullable="false" primaryKey="true" primaryKeyName="grupo_relacion_institucionalPK" />
      </column>
      <column name="created_by" type="VARCHAR(255)" />
      <column name="creation_date" type="TIMESTAMP" />
      <column name="last_modified_by" type="VARCHAR(255)" />
      <column name="last_modified_date" type="TIMESTAMP" />
      <column name="grupo_id" type="BIGINT">
        <constraints nullable="false" />
      </column>
      <column name="entidad_ref" type="VARCHAR(255)" />
      <column name="institucion" type="VARCHAR(1000)" />
    </createTable>

    <addForeignKeyConstraint baseColumnNames="grupo_id"
      baseTableName="grupo_relacion_institucional"
      constraintName="FK_GRUPORELACIONINSTITUCIONAL_GRUPO"
      deferrable="false" initiallyDeferred="false"
      referencedColumnNames="id" referencedTableName="grupo" validate="true" />

    <addUniqueConstraint columnNames="grupo_id, entidad_ref"
      constraintName="UK_GRUPORELACIONINSTITUCIONAL_GRUPO_ENTIDADREF"
      tableName="grupo_relacion_institucional" />
    <addUniqueConstraint columnNames="grupo_id, institucion"
      constraintName="UK_GRUPORELACIONINSTITUCIONAL_GRUPO_INSTITUCION"
      tableName="grupo_relacion_institucional" />
  </changeSet>

  <changeSet author="master" id="1.1.0-18">
    <createSequence sequenceName="tipo_confidencialidad_seq" startValue="1" incrementBy="1" />
  </changeSet>

  <changeSet author="master" id="1.1.0-19">
    <createTable tableName="tipo_confidencialidad">
      <column name="id" type="BIGINT">
        <constraints primaryKey="true" nullable="false" />
      </column>
      <column name="activo" type="BOOLEAN" defaultValueBoolean="true">
        <constraints nullable="false" />
      </column>
      <column name="created_by" type="VARCHAR(255)" />
      <column name="creation_date" type="TIMESTAMP" />
      <column name="last_modified_by" type="VARCHAR(255)" />
      <column name="last_modified_date" type="TIMESTAMP" />
      <!-- Columna temporal para mapear los valores del booleano en la migración -->
      <column name="codigo" type="VARCHAR(50)" />
    </createTable>
  </changeSet>

  <changeSet author="master" id="1.1.0-20">
    <createTable tableName="tipo_confidencialidad_nombre">
      <column name="tipo_confidencialidad_id" type="BIGINT">
        <constraints nullable="false" />
      </column>
      <column name="lang" type="VARCHAR(2)">
        <constraints nullable="false" />
      </column>
      <column name="value_" type="VARCHAR(50)">
        <constraints nullable="false" />
      </column>
    </createTable>

    <addPrimaryKey tableName="tipo_confidencialidad_nombre"
      columnNames="tipo_confidencialidad_id, lang" />

    <addForeignKeyConstraint baseColumnNames="tipo_confidencialidad_id"
      baseTableName="tipo_confidencialidad_nombre"
      constraintName="FK_TIPOCONFIDENCIALIDADNOMBRE_TIPOCONFIDENCIALIDAD"
      deferrable="false" initiallyDeferred="false"
      referencedColumnNames="id" referencedTableName="tipo_confidencialidad" validate="true" />
  </changeSet>

  <changeSet author="master" id="1.1.0-21">
    <addColumn tableName="proyecto">
      <column name="tipo_confidencialidad_id" type="BIGINT" />
    </addColumn>

    <addForeignKeyConstraint baseColumnNames="tipo_confidencialidad_id"
      baseTableName="proyecto"
      constraintName="FK_PROYECTO_TIPOCONFIDENCIALIDAD"
      deferrable="false" initiallyDeferred="false"
      referencedColumnNames="id" referencedTableName="tipo_confidencialidad" validate="true" />
  </changeSet>

  <changeSet author="master" id="1.1.0-22">
    <addColumn tableName="proyecto">
      <column name="tipo_regimen_concurrencia_id" type="BIGINT" />
    </addColumn>

    <addForeignKeyConstraint baseColumnNames="tipo_regimen_concurrencia_id"
      baseTableName="proyecto"
      constraintName="FK_PROYECTO_REGIMENCONCURRENCIA"
      deferrable="false" initiallyDeferred="false"
      referencedColumnNames="id" referencedTableName="tipo_regimen_concurrencia" validate="true" />
  </changeSet>

  <changeSet author="master" id="1.1.0-23">
    <modifyDataType tableName="proyecto_titulo" columnName="value_" newDataType="VARCHAR(1000)" />
  </changeSet>

  <changeSet author="master" id="1.1.0-24">
    <renameColumn tableName="proyecto_observaciones" oldColumnName="value_" newColumnName="value_old" />

    <addColumn tableName="proyecto_observaciones">
      <column name="value_" type="CLOB" />
    </addColumn>

    <sql>UPDATE ${schemaPrefix}proyecto_observaciones SET value_ = value_old</sql>

    <dropColumn columnName="value_old" tableName="proyecto_observaciones" />

    <addNotNullConstraint tableName="proyecto_observaciones" columnName="value_"
      columnDataType="CLOB" />
  </changeSet>

</databaseChangeLog>
